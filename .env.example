# Copy to .env before running: cp .env.example .env
#
# Docker Compose reads these values for BOTH the db and app services.
# PostgreSQL only applies POSTGRES_PASSWORD on first volume creation.
# If you change the password later, run: docker compose down -v

POSTGRES_DB=miner_rewards
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
FULFILLMENT_API_KEY=change-me-for-fulfillment
PORT=3000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Local development only (not used by Docker Compose app service)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/miner_rewards?schema=public
